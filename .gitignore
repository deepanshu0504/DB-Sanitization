# .gitignore for Database Sanitization Framework

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# Logs
*.log
logs/

# Database
*.db
*.sqlite
*.sqlite3

# Environment variables
.env
.env.local
.env.*.local

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Configuration files with sensitive data
config/config.json
config/pii_config.json
config/*.local.json

# Mapping tables (contains PII)
mapping_*.db
mappings/

# SQL Server credentials
sqlconfig.json
db_credentials.json

# OS
Thumbs.db
Desktop.ini

# Documentation builds
docs/_build/
site/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# pylint
.pylint.d/
# Output files
sanitize_output.txt
nul
