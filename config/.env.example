# Database Sanitization Framework - Environment Variables
# Copy this file to .env and update with your actual values
# Never commit .env to version control!

# ============================================
# Database Connection Settings
# ============================================

# SQL Server hostname or IP address
SANITIZATION_DATABASE_SERVER=localhost

# Database name to sanitize
SANITIZATION_DATABASE_DATABASE=SanitizationTest

# Authentication type: "windows" or "sql"
SANITIZATION_DATABASE_AUTH_TYPE=windows

# SQL Server Authentication (only required if AUTH_TYPE=sql)
# SANITIZATION_DATABASE_USERNAME=your_username
# SANITIZATION_DATABASE_PASSWORD=your_password

# Connection timeout in seconds (5-300, default: 30)
# SANITIZATION_DATABASE_TIMEOUT=30

# ============================================
# Performance & Batch Processing
# ============================================

# Number of rows to process per batch (100-1000000, default: 10000)
# SANITIZATION_DATABASE_BATCH_SIZE=10000

# Maximum retry attempts for transient failures (0-10, default: 3)
# SANITIZATION_DATABASE_MAX_RETRIES=3

# Initial retry delay in seconds (0.1-60.0, default: 1.0)
# SANITIZATION_DATABASE_RETRY_DELAY=1.0

# Connection pool size (1-20, default: 5)
# SANITIZATION_DATABASE_POOL_SIZE=5

# ============================================
# Environment Settings
# ============================================

# Deployment environment: "dev", "staging", or "prod"
# SANITIZATION_DATABASE_ENVIRONMENT=dev

# ============================================
# Notes
# ============================================
# 
# - Environment variables override values in JSON config files
# - Use environment variables for sensitive data (passwords, usernames)
# - Store non-sensitive defaults in JSON config files
# - Boolean values: use "true"/"false", "yes"/"no", or "1"/"0"
# - Numeric values will be automatically type-converted
#
# Example for Production:
# SANITIZATION_DATABASE_SERVER=prod-sqlserver.example.com
# SANITIZATION_DATABASE_DATABASE=ProductionDB
# SANITIZATION_DATABASE_AUTH_TYPE=sql
# SANITIZATION_DATABASE_USERNAME=sanitization_user
# SANITIZATION_DATABASE_PASSWORD=SecureP@ssw0rd123
# SANITIZATION_DATABASE_ENVIRONMENT=prod
# SANITIZATION_DATABASE_BATCH_SIZE=20000
