{
  "database": {
    "server": "(localdb)\\MSSQLLocalDB",
    "database": "Testsanitization",
    "auth_type": "windows",
    "timeout": 60,
    "batch_size": 5000,
    "max_retries": 5,
    "retry_delay": 1.0,
    "pool_size": 10,
    "environment": "dev",
    "log_batch_frequency": 10,
    "bulk_update_strategy": "auto",
    "enable_fast_executemany": true,
    "enable_parallel_processing": true,
    "max_parallel_tables": 4
  },
  "mapping_capture": {
    "enabled": true,
    "skip_on_dry_run": true,
    "batch_size": 5000,
    "performance_threshold_percent": 5,
    "_comment": "Mapping capture enables reversible sanitization (desanitization). Set 'enabled': false to disable. 'skip_on_dry_run': true prevents mapping creation during dry runs. Performance threshold alerts if overhead exceeds specified percentage."
  },
  "mapping_encryption": {
    "enabled": false,
    "key_source": "environment",
    "key_env_var": "MAPPING_ENCRYPTION_KEY",
    "fallback_keys_env_vars": [],
    "performance_threshold_percent": 10,
    "_comment": "Story 1.3: Encryption at rest for mapping table values. Uses AES-256-GCM authenticated encryption. Set 'enabled': true to encrypt original_value and masked_value columns. 'key_source' options: 'environment' (current), 'azure_key_vault' (future). Generate key: python -c \"from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())\". Store key in environment variable specified by 'key_env_var'. For key rotation, add old keys to 'fallback_keys_env_vars'. Performance threshold alerts if encryption overhead exceeds specified percentage (default: 10%)."
  },
  "mapping_performance": {
    "cache_enabled": false,
    "cache_size": 10000,
    "cache_ttl_seconds": null,
    "auto_analyze_performance": false,
    "_comment": "Story 5.3: Performance optimization for mapping lookups. 'cache_enabled': Enable LRU cache for frequently accessed mappings (reduces database load). 'cache_size': Maximum cache entries (default: 10000, recommended 10% of distinct masked values). 'cache_ttl_seconds': Optional time-to-live for cache entries in seconds (null = no expiration, mappings cached until eviction). 'auto_analyze_performance': Automatically log query performance metrics (disable in production). Caching recommended for repeated desanitizations of same batch. Monitor hit rate with MappingTableManager.cache.get_metrics()."
  },
  "logging": {
    "level": "INFO",
    "handlers": [
      {
        "type": "console",
        "format_json": false
      },
      {
        "type": "file",
        "file_path": "logs/sanitization.log",
        "max_bytes": 104857600,
        "backup_count": 10,
        "rotation_interval": "daily",
        "format_json": true
      }
    ],
    "pii_redaction": {
      "enabled": true,
      "redact_emails": true,
      "redact_phones": true,
      "redact_ssn": true,
      "redact_credit_cards": true,
      "patterns": {}
    },
    "include_correlation_id": true,
    "log_format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  },
  "ai": {
    "enabled": true,
    "api_url": "https://models.github.ai/inference/chat/completions",
    "api_key_env_var": "GITHUB_COPILOT_TOKEN",
    "model": "gpt-4o",
    "timeout_seconds": 60,
    "max_retries": 3,
    "retry_backoff_factor": 1.0,
    "cache_enabled": true,
    "cache_ttl_hours": 24,
    "max_tables_per_request": 50,
    "max_schema_size_chars": 100000
  },
  "pii_columns": [
    {
      "schema": "dbo",
      "table": "Customers",
      "column": "Email",
      "pii_type": "email",
      "nullable": false
    },
    {
      "schema": "dbo",
      "table": "Customers",
      "column": "Phone",
      "pii_type": "phone",
      "nullable": true
    },
    {
      "schema": "dbo",
      "table": "Customers",
      "column": "FirstName",
      "pii_type": "name",
      "nullable": false
    },
    {
      "schema": "dbo",
      "table": "Customers",
      "column": "LastName",
      "pii_type": "name",
      "nullable": false
    },
    {
      "schema": "dbo",
      "table": "Employees",
      "column": "SSN",
      "pii_type": "ssn",
      "nullable": false
    },
    {
      "schema": "dbo",
      "table": "Employees",
      "column": "PersonalEmail",
      "pii_type": "email",
      "nullable": true
    },
    {
      "schema": "sales",
      "table": "Orders",
      "column": "BillingEmail",
      "pii_type": "email",
      "nullable": false
    },
    {
      "schema": "dbo",
      "table": "Products",
      "column": "InternalCode",
      "pii_type": "generic",
      "nullable": true,
      "custom_format": {
        "character_class": "alpha"
      },
      "_comment": "GenericMasker with alpha-only character class"
    },
    {
      "schema": "dbo",
      "table": "Orders",
      "column": "ReferenceNumber",
      "pii_type": "generic",
      "nullable": false,
      "custom_format": {
        "character_class": "numeric"
      },
      "_comment": "GenericMasker with numeric-only character class"
    },
    {
      "schema": "dbo",
      "table": "Inventory",
      "column": "SKU",
      "pii_type": "generic",
      "nullable": false,
      "custom_format": {
        "character_class": "alphanumeric"
      },
      "_comment": "GenericMasker with alphanumeric character class (default)"
    }
  ],
  "dry_run": false,
  "validate_before": true,
  "validate_after": true
}
